{
    "name": "devlinks",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "start": "node .output/server/index.mjs",
        "lint": "oxlint --type-aware --type-check",
        "lint:fix": "oxlint --type-aware --type-check --fix",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "check": "pnpm format && pnpm lint",
        "prepare": "husky",
        "db": "drizzle-kit",
        "deps": "pnpm dlx taze@latest -Ilw",
        "deps:major": "pnpm dlx taze@latest major -Ilw",
        "tanstack": "pnpm dlx @tanstack/cli@latest",
        "ui": "pnpm dlx shadcn@latest",
        "auth": "pnpm dlx auth@latest",
        "auth:secret": "pnpm dlx auth@latest secret",
        "auth:generate": "pnpm dlx auth@latest generate --config ./src/lib/auth/auth.ts --y --output ./src/lib/db/schema/auth.schema.ts",
        "auth:migrate": "pnpm run auth:generate && pnpm run db generate && pnpm run db migrate"
    },
    "dependencies": {
        "@base-ui/react": "^1.2.0",
        "@better-auth/drizzle-adapter": "^1.5.4",
        "@fontsource-variable/dm-sans": "^5.2.8",
        "@hookform/resolvers": "^5.2.2",
        "@remixicon/react": "^4.9.0",
        "@t3-oss/env-core": "^0.13.10",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-router": "^1.166.2",
        "@tanstack/react-router-ssr-query": "^1.166.2",
        "@tanstack/react-start": "^1.166.2",
        "@upstash/redis": "^1.36.3",
        "better-auth": "^1.5.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.1",
        "nitro": "npm:nitro-nightly@latest",
        "postgres": "^3.4.8",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.71.2",
        "shadcn": "^4.0.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.3",
        "@commitlint/config-conventional": "^20.4.3",
        "@tailwindcss/vite": "^4.2.1",
        "@tanstack/devtools-vite": "^0.5.3",
        "@tanstack/eslint-plugin-query": "^5.91.4",
        "@tanstack/eslint-plugin-router": "^1.161.4",
        "@tanstack/react-devtools": "^0.9.10",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@tanstack/react-router-devtools": "^1.166.2",
        "@types/node": "^24.12.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "babel-plugin-react-compiler": "^1.0.0",
        "drizzle-kit": "^0.31.9",
        "eslint-plugin-react-hooks": "^7.0.1",
        "husky": "9.1.7",
        "lint-staged": "^16.3.2",
        "oxfmt": "^0.36.0",
        "oxlint": "^1.51.0",
        "oxlint-tsgolint": "^0.16.0",
        "tailwindcss": "^4.2.1",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.0-beta.16"
    },
    "lint-staged": {
        "*": "oxfmt --no-error-on-unmatched-pattern"
    }
}
